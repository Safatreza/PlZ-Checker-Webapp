# Environment Variables Configuration
# Copy this file to .env.local and fill in your values

# Application URL (for CORS configuration)
# In development: http://localhost:3000
# In production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
# Timeout for external API calls (in milliseconds)
API_TIMEOUT=10000

# Nominatim API Configuration
NOMINATIM_USER_AGENT=PLZ-Router/1.0 (https://plz-checker-webapp.vercel.app)
NOMINATIM_TIMEOUT=8000

# Rate Limiting (if implemented)
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=900000

# Error Tracking (if using Sentry or similar)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Analytics (if using Vercel Analytics or similar)
# NEXT_PUBLIC_ANALYTICS_ID=

# Environment
NODE_ENV=development
